generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

// ==========================================
// AUTHENTICATION (Phase 1 Extended)
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  pinHash       String?
  role          Role      @default(USER)
  roleId        String?
  roleDefinition RoleDefinition? @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fcmToken      String?
  themePantoneTcx  String?
  themePrimaryHex  String    @default("#334155")
  themePantone     PantoneColor? @relation(fields: [themePantoneTcx], references: [tcx], onDelete: SetNull, onUpdate: NoAction)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  auditLogs       AuditLog[]
  pinAttempts     PinAttempt[]
  notificationQueue NotificationQueue[]
  purchaseOrders PurchaseOrder[]
  poStatusChanges POStatusHistory[]
  stockAdjustmentsApproved StockAdjustment[] @relation("ApprovedAdjustments")
  stockAdjustmentsCreated  StockAdjustment[] @relation("CreatedAdjustments")
  vendorReturnsCreated    VendorReturn[]
  vendorReturnsCompleted  VendorReturn[] @relation("VendorReturnCompleted")
  pantoneColorFavorites   PantoneColorFavorite[]
  planYearsCreated        PlanYear[]
  salesHistoryImports     SalesHistoryImport[]
  forecastConfigsCreated  ForecastConfig[]
  suppliersApproved       Supplier[]
  grnsOwnerApproved       GRN[]      @relation("GRNOwnerApproved")
  grnsOwnerDeclined       GRN[]      @relation("GRNOwnerDeclined")
  enqueuedOutbox          JubelioOutbox[] @relation("EnqueuedOutbox")
  jubelioPushDefaultsUpdates JubelioPushDefaults[] @relation("JubelioPushDefaultsUpdater")
  priceChangeLogs         ItemPriceChangeLog[]
  salesReturnsDecided     SalesReturn[]     @relation("SalesReturnDecidedBy")
  salesReturnItemsDecided SalesReturnItem[] @relation("SalesReturnItemDecidedBy")
  storeVisits   StoreVisit[]
  fieldSalesOrders FieldSalesOrder[] @relation("FieldSalesOrderSalesman")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([roleId])
  @@index([themePantoneTcx])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// RBAC (Role-Based Access Control)
// ==========================================
model RoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissionsVersion Int @default(1)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique    // e.g. "suppliers:create"
  module      String              // e.g. "suppliers"
  action      String              // e.g. "create"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String         @id @default(cuid())
  roleId       String
  permissionId String
  role         RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ==========================================
// MASTER DATA (Phase 2)
// ==========================================
model SupplierType {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  isActive  Boolean    @default(true)
  sortOrder Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  suppliers Supplier[]
}

model Supplier {
  id               String           @id @default(cuid())
  code             String           @unique
  name             String
  typeId           String
  type             SupplierType    @relation(fields: [typeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  address          String?
  phone            String?
  email            String?
  bankName         String?
  bankAccountEnc   String?
  bankAccountName  String?
  isActive         Boolean          @default(true)
  status           SupplierStatus  @default(PENDING_APPROVAL)
  approvedById     String?
  approvedBy       User?           @relation(fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt       DateTime?
  rejectionReason  String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  purchaseOrders   PurchaseOrder[]
  workOrders       WorkOrder[]
  workOrderSteps   WorkOrderStep[]
  grns             GRN[]
  vendorReturns    VendorReturn[]
  planCmtAllocations PlanCmtAllocation[]
  planStages       PlanStage[]      @relation("PlanStageSupplier")
  @@index([typeId])
  @@index([code])
  @@index([status])
  @@index([approvedById])
}

model UOM {
  id              String          @id @default(cuid())
  code            String          @unique
  nameId          String
  nameEn          String
  description     String?
  isActive        Boolean         @default(true)
  items           Item[]
  fabricRolls     FabricRoll[]
  fromConversions UOMConversion[] @relation("FromConversions")
  toConversions   UOMConversion[] @relation("ToConversions")
  createdAt       DateTime        @default(now())
}

model UOMConversion {
  id          String   @id @default(cuid())
  fromUomId   String
  toUomId     String
  fromUom     UOM      @relation("FromConversions", fields: [fromUomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toUom       UOM      @relation("ToConversions", fields: [toUomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  factor      Decimal  @db.Decimal(10,6)
  isDefault   Boolean  @default(false)
  @@unique([fromUomId, toUomId])
  @@index([fromUomId])
  @@index([toUomId])
}

model ItemCategory {
  id        String   @id @default(cuid())
  code      String?  @unique
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items            Item[]
  jubelioCategoryMappings JubelioCategoryMapping[]
  planCategories   PlanCategory[]
}

model Store {
  id             String         @id @default(cuid())
  code           String         @unique
  name           String
  address        String         @db.Text
  phone          String?
  contactName    String?
  termsType      StoreTermsType
  paymentTempo   Int            @default(0)
  marginPercent  Decimal?       @db.Decimal(5, 2)
  lat            Decimal?       @db.Decimal(10, 7)
  lng            Decimal?       @db.Decimal(10, 7)
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  visits         StoreVisit[]
  fieldSalesOrders FieldSalesOrder[]
  promoStores    PromoStore[]

  @@index([isActive, name])
}

model StoreVisit {
  id           String    @id @default(cuid())
  storeId      String
  userId       String
  checkinAt    DateTime  @default(now())
  checkoutAt   DateTime?
  checkinLat   Decimal   @db.Decimal(10, 7)
  checkinLng   Decimal   @db.Decimal(10, 7)
  checkoutLat  Decimal?  @db.Decimal(10, 7)
  checkoutLng  Decimal?  @db.Decimal(10, 7)
  autoClosed   Boolean   @default(false)

  store        Store     @relation(fields: [storeId], references: [id])
  user         User      @relation(fields: [userId], references: [id])
  fieldSalesOrders FieldSalesOrder[]

  @@index([userId, checkoutAt])
  @@index([storeId, checkinAt])
}

model FieldSalesOrder {
  id            String                @id @default(cuid())
  orderNo       String                @unique
  storeId       String
  salesmanId    String
  visitId       String?
  status        FieldSalesOrderStatus @default(PENDING_APPROVAL)
  orderType     FieldSalesOrderType   @default(PUTUS)
  subtotal      Decimal               @db.Decimal(15, 2)
  total         Decimal               @db.Decimal(15, 2)
  orderDiscountAmount Decimal         @default(0) @db.Decimal(15, 2)
  appliedOrderPromoId String?
  note          String?               @db.Text
  approvedAt    DateTime?
  approvedById  String?
  rejectedAt    DateTime?
  rejectedById  String?
  rejectReason  String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  store         Store                 @relation(fields: [storeId], references: [id])
  salesman      User                  @relation("FieldSalesOrderSalesman", fields: [salesmanId], references: [id])
  visit         StoreVisit?           @relation(fields: [visitId], references: [id])
  lines         FieldSalesOrderLine[]
  @@index([status, createdAt])
  @@index([storeId, createdAt])
  @@index([salesmanId, createdAt])
}

model FieldSalesOrderLine {
  id           String          @id @default(cuid())
  orderId      String
  itemId       String
  variantSku   String          @default("")
  productName  String
  qty          Int
  unitPrice    Decimal         @db.Decimal(15, 2)
  lineTotal    Decimal         @db.Decimal(15, 2)
  discountAmount Decimal       @default(0) @db.Decimal(15, 2)
  appliedPromoId String?
  order        FieldSalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  item         Item            @relation(fields: [itemId], references: [id])
  @@index([orderId])
  @@index([itemId])
}

enum FieldSalesOrderStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum FieldSalesOrderType {
  PUTUS
  KONSI
}

enum ReserveSource {
  JUBELIO
  FIELD_SALES
  FIELD_SALES_KONSI
}

enum PromoType {
  PERCENT
  FIXED
  TIERED
}

enum PromoLevel {
  LINE
  ORDER
}

model Promo {
  id               String         @id @default(cuid())
  name             String
  type             PromoType
  level            PromoLevel
  termsType        StoreTermsType @default(PUTUS)
  value            Decimal?       @db.Decimal(15, 2)
  minQty           Int?
  minOrderSubtotal Decimal?       @db.Decimal(15, 2)
  minOrderQty      Int?
  allStores        Boolean        @default(true)
  startsAt         DateTime?
  endsAt           DateTime?
  priority         Int            @default(0)
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  items            PromoItem[]
  stores           PromoStore[]
  tiers            PromoTier[]
  @@index([isActive, level])
}

model PromoItem {
  id      String @id @default(cuid())
  promoId String
  itemId  String
  promo   Promo  @relation(fields: [promoId], references: [id], onDelete: Cascade)
  item    Item   @relation(fields: [itemId], references: [id])
  @@unique([promoId, itemId])
  @@index([itemId])
}

model PromoStore {
  id      String @id @default(cuid())
  promoId String
  storeId String
  promo   Promo  @relation(fields: [promoId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id])
  @@unique([promoId, storeId])
  @@index([storeId])
}

model PromoTier {
  id        String  @id @default(cuid())
  promoId   String
  minQty    Int
  unitPrice Decimal @db.Decimal(15, 2)
  promo     Promo   @relation(fields: [promoId], references: [id], onDelete: Cascade)
  @@unique([promoId, minQty])
}

model Item {
  id               String            @id @default(cuid())
  sku              String            @unique
  nameId           String
  nameEn           String
  description      String?
  type             ItemType
  uomId            String
  uom              UOM               @relation(fields: [uomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categoryId       String?
  category         ItemCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  variants         Json?
  isActive         Boolean           @default(true)
  reorderPoint     Decimal?          @db.Decimal(10,2)
  overReceiveThreshold Decimal?      @db.Decimal(10,2)
  sellingPrice     Decimal?          @db.Decimal(14,2)
  targetMarginPercent Decimal?       @db.Decimal(5,2)
  additionalCost   Decimal?          @db.Decimal(15,2)
  defaultPpnIncluded Boolean         @default(true)
  minOrderQty      Int?
  source           ItemSource        @default(ERP)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  stockMovements   StockMovement[]
  poItems          POItem[]
  inventoryValues  InventoryValue[]
  fgConsumptions   ConsumptionRule[] @relation("FGConsumptions")
  materialUsages   ConsumptionRule[] @relation("MaterialUsages")
  stockAdjustments StockAdjustment[]
  workOrdersAsFinishedGood WorkOrder[]
  workOrdersAsConsumptionMaterial WorkOrder[] @relation("WorkOrderConsumptionMaterial")
  planCategories   PlanCategory[]
  planAccessories  PlanAccessory[]
  rejectedGoodsLedger RejectedGoodsLedger[]
  fabricRolls      FabricRoll[]
  jubelioProductMappings JubelioProductMapping[]
  priceChangeLogs  ItemPriceChangeLog[]
  salesReturnItems SalesReturnItem[]
  salesHistoryRows   SalesHistory[]
  forecastResults    ForecastResult[]
  images           ItemImage[]
  fieldSalesLines  FieldSalesOrderLine[]
  promoItems       PromoItem[]
  @@index([type, isActive])
  @@index([sku])
  @@index([uomId])
  @@index([categoryId])
}

model ItemImage {
  id                      String    @id @default(cuid())
  itemId                  String
  item                    Item      @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  variantSku              String?
  url                     String    @db.VarChar(500)
  sortOrder               Int       @default(0)
  jubelioImageId          String?   @unique
  jubelioImageKey         String?   @db.VarChar(500)
  jubelioImageThumbnail   String?   @db.VarChar(500)
  syncedAt                DateTime?
  source                  String    @default("ERP_UPLOAD")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  @@index([itemId, variantSku, sortOrder])
  @@index([itemId, jubelioImageId])
}

model ConsumptionRule {
  id              String   @id @default(cuid())
  finishedGoodId  String
  finishedGood    Item     @relation("FGConsumptions", fields: [finishedGoodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  materialId      String
  material        Item     @relation("MaterialUsages", fields: [materialId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  qtyRequired     Decimal  @db.Decimal(10,4)
  wastePercent    Decimal  @default(0) @db.Decimal(5,2)
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  @@unique([finishedGoodId, materialId])
  @@index([finishedGoodId])
  @@index([materialId])
}

// ==========================================
// PROCUREMENT (Phase 2)
// ==========================================
model PurchaseOrder {
  id          String          @id @default(cuid())
  docNumber   String          @unique
  supplierId  String
  supplier    Supplier        @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           POStatus        @default(DRAFT)
  etaDate          DateTime?
  paymentDueDate   DateTime?
  paidAt           DateTime?
  currency         String          @default("IDR")
  totalAmount      Decimal         @default(0) @db.Decimal(15,2)
  taxAmount        Decimal         @default(0) @db.Decimal(15,2)
  grandTotal       Decimal         @default(0) @db.Decimal(15,2)
  notes            String?        @db.Text
  terms            String?        @db.Text
  createdById      String
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items       POItem[]
  grns        GRN[]
  statusHistory POStatusHistory[]
  workOrders  WorkOrder[]
  syncStatus  SyncStatus      @default(SYNCED)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([supplierId])
  @@index([createdById])
  @@index([status])
  @@index([etaDate])
  @@index([docNumber])
}

model POItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /** Matches Item.variants[].sku; null = non-variant / parent SKU stock bucket */
  variantSku  String?
  qty         Decimal       @db.Decimal(10,2)
  price       Decimal       @db.Decimal(15,2)
  ppnIncluded Boolean       @default(true)
  receivedQty Decimal       @default(0) @db.Decimal(10,2)
  uomId       String
  notes       String?
  createdAt   DateTime      @default(now())
  @@index([poId])
  @@index([itemId])
  @@index([poId, itemId, variantSku])
}

model POStatusHistory {
  id            String        @id @default(cuid())
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  status        POStatus
  changedById   String
  changedBy     User          @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes         String?
  paymentEvent  String?       // 'MARKED' | 'UNMARKED' when record is for supplier payment marked/unmarked
  createdAt     DateTime      @default(now())
  @@index([poId, createdAt])
  @@index([changedById])
}

// ==========================================
// INVENTORY & COSTING (Phase 3)
// ==========================================
model InventoryValue {
  id          String   @id @default(cuid())
  itemId      String
  variantSku  String?
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  qtyOnHand   Decimal  @default(0) @db.Decimal(10,2)
  reservedQty Decimal  @default(0) @db.Decimal(10,2)
  avgCost     Decimal  @default(0) @db.Decimal(15,2)
  totalValue  Decimal  @default(0) @db.Decimal(15,2)
  lastUpdated DateTime @default(now())
  @@unique([itemId, variantSku])
  @@index([itemId])
}

model GRN {
  id            String    @id @default(cuid())
  docNumber     String    @unique
  poId          String?
  po            PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grnDate       DateTime  @default(now())
  receivedBy    String
  totalAmount   Decimal   @db.Decimal(15,2)
  notes         String?
  photoUrls     String?
  items         Json      
  requiresOwnerApproval Boolean @default(false)
  ownerApprovedAt DateTime?
  ownerApprovedById String?
  ownerApprovedBy User?    @relation("GRNOwnerApproved", fields: [ownerApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownerDeclinedAt DateTime?
  ownerDeclinedById String?
  ownerDeclinedBy User?    @relation("GRNOwnerDeclined", fields: [ownerDeclinedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  syncStatus    SyncStatus @default(SYNCED)
  localId       String?
  createdAt     DateTime  @default(now())
  fabricRolls   FabricRoll[]
  vendorReturns VendorReturn[]
  @@index([poId])
  @@index([supplierId])
  @@index([grnDate])
  @@index([docNumber])
  @@index([ownerApprovedById])
  @@index([ownerDeclinedById])
}

model FabricRoll {
  id            String   @id @default(cuid())
  grnId         String
  grn           GRN      @relation(fields: [grnId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  itemId        String
  item          Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rollCode      String   @unique
  rollRef       String
  initialLength Decimal  @db.Decimal(10,2)
  remainingLength Decimal @db.Decimal(10,2)
  uomId         String
  uom           UOM      @relation(fields: [uomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isClosed      Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  @@index([grnId])
  @@index([itemId])
  @@index([itemId, isClosed, remainingLength])
  @@index([uomId])
  @@index([rollCode])
}

model StockMovement {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type         MoveType
  refType      String
  refId        String
  refDocNumber String
  qty          Decimal  @db.Decimal(10,2)
  variantSku   String?
  unitCost     Decimal? @db.Decimal(15,2)
  totalCost    Decimal? @db.Decimal(15,2)
  balanceQty   Decimal  @db.Decimal(10,2)
  balanceValue Decimal  @db.Decimal(15,2)
  notes        String?
  createdAt    DateTime @default(now())
  @@index([itemId, createdAt])
  @@index([refType, refId])
}

model StockAdjustment {
  id            String   @id @default(cuid())
  docNumber     String   @unique
  itemId        String
  item          Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type          AdjustmentType
  qtyChange     Decimal  @db.Decimal(10,2)
  reason        String
  evidenceUrl   String?
  prevQty       Decimal  @db.Decimal(10,2)
  newQty        Decimal  @db.Decimal(10,2)
  prevAvgCost   Decimal  @db.Decimal(15,2)
  newAvgCost    Decimal  @db.Decimal(15,2)
  approvedById  String?
  approvedBy    User?    @relation("ApprovedAdjustments", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById   String?
  createdBy     User?    @relation("CreatedAdjustments", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  source           String   @default("ERP")
  idempotencyKey   String?  @unique
  externalRef      String?
  createdAt     DateTime @default(now())
  salesReturnItem SalesReturnItem?
  @@index([itemId])
  @@index([approvedById])
  @@index([createdById])
  @@index([docNumber])
  @@index([source, createdAt])
}

model StockOpname {
  id            String        @id @default(cuid())
  docNumber     String        @unique
  scope         OpnameScope
  status        OpnameStatus  @default(CREATED)
  notes         String?       @db.Text
  snapshotAt    DateTime
  assignedToId  String?
  createdById   String
  submittedById String?
  submittedAt   DateTime?
  approvedById  String?
  approvedAt    DateTime?
  cancelledAt   DateTime?
  items         StockOpnameItem[]
  rolls         StockOpnameRoll[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  @@index([scope])
  @@index([status])
  @@index([docNumber])
  @@index([createdById])
}

model StockOpnameItem {
  id                   String      @id @default(cuid())
  opnameId             String
  opname               StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  itemId               String
  variantSku           String?
  itemName             String
  snapshotQty          Decimal     @db.Decimal(10,2)
  countedQty           Decimal?    @db.Decimal(10,2)
  variance             Decimal?    @db.Decimal(10,2)
  currentQtyAtApproval Decimal?    @db.Decimal(10,2)
  hadDriftWarning      Boolean     @default(false)
  adjustmentId         String?
  notes                String?
  @@index([opnameId])
  @@index([itemId])
}

model StockOpnameRoll {
  id              String      @id @default(cuid())
  opnameId        String
  opname          StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  fabricRollId    String
  rollCode        String
  itemName        String
  snapshotLength  Decimal     @db.Decimal(10,2)
  countedLength   Decimal?    @db.Decimal(10,2)
  variance        Decimal?    @db.Decimal(10,2)
  notes           String?
  @@index([opnameId])
  @@index([fabricRollId])
}

model ReconciliationRun {
  id            String    @id @default(cuid())
  triggeredBy   ReconTrigger
  status        ReconRunStatus @default(RUNNING)
  totalScanned  Int       @default(0)
  inSync        Int       @default(0)
  autoCorrected Int       @default(0)
  flagged       Int       @default(0)

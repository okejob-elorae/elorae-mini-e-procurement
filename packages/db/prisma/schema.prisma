  planCmtAllocations PlanCmtAllocation[]
  @@index([poId])
  @@index([vendorId])
  @@index([finishedGoodId])
  @@index([consumptionMaterialId])
  @@index([createdById])
  @@index([status])
  @@index([targetDate])
  @@index([docNumber])
}

model WorkOrderStep {
  id                 String   @id @default(cuid())

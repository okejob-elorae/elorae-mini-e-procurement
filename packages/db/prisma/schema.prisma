generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider     = "mysql"
  relationMode = "prisma"
}

// ==========================================
// AUTHENTICATION (Phase 1 Extended)
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  pinHash       String?
  role          Role      @default(USER)
  roleId        String?
  roleDefinition RoleDefinition? @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fcmToken      String?
  themePantoneTcx  String?
  themePrimaryHex  String    @default("#334155")
  themePantone     PantoneColor? @relation(fields: [themePantoneTcx], references: [tcx], onDelete: SetNull, onUpdate: NoAction)
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  auditLogs       AuditLog[]
  pinAttempts     PinAttempt[]
  notificationQueue NotificationQueue[]
  purchaseOrders PurchaseOrder[]
  poStatusChanges POStatusHistory[]
  stockAdjustmentsApproved StockAdjustment[] @relation("ApprovedAdjustments")
  stockAdjustmentsCreated  StockAdjustment[] @relation("CreatedAdjustments")
  vendorReturnsCreated    VendorReturn[]
  vendorReturnsCompleted  VendorReturn[] @relation("VendorReturnCompleted")
  pantoneColorFavorites   PantoneColorFavorite[]
  planYearsCreated        PlanYear[]
  salesHistoryImports     SalesHistoryImport[]
  forecastConfigsCreated  ForecastConfig[]
  suppliersApproved       Supplier[]
  grnsOwnerApproved       GRN[]      @relation("GRNOwnerApproved")
  grnsOwnerDeclined       GRN[]      @relation("GRNOwnerDeclined")
  enqueuedOutbox          JubelioOutbox[] @relation("EnqueuedOutbox")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@index([roleId])
  @@index([themePantoneTcx])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ==========================================
// RBAC (Role-Based Access Control)
// ==========================================
model RoleDefinition {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissionsVersion Int @default(1)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique    // e.g. "suppliers:create"
  module      String              // e.g. "suppliers"
  action      String              // e.g. "create"
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String         @id @default(cuid())
  roleId       String
  permissionId String
  role         RoleDefinition @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission     @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ==========================================
// MASTER DATA (Phase 2)
// ==========================================
model SupplierType {
  id        String     @id @default(cuid())
  code      String     @unique
  name      String
  isActive  Boolean    @default(true)
  sortOrder Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  suppliers Supplier[]
}

model Supplier {
  id               String           @id @default(cuid())
  code             String           @unique
  name             String
  typeId           String
  type             SupplierType    @relation(fields: [typeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  address          String?
  phone            String?
  email            String?
  bankName         String?
  bankAccountEnc   String?
  bankAccountName  String?
  isActive         Boolean          @default(true)
  status           SupplierStatus  @default(PENDING_APPROVAL)
  approvedById     String?
  approvedBy       User?           @relation(fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvedAt       DateTime?
  rejectionReason  String?          @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  purchaseOrders   PurchaseOrder[]
  workOrders       WorkOrder[]
  workOrderSteps   WorkOrderStep[]
  grns             GRN[]
  vendorReturns    VendorReturn[]
  planCmtAllocations PlanCmtAllocation[]
  planStages       PlanStage[]      @relation("PlanStageSupplier")
  @@index([typeId])
  @@index([code])
  @@index([status])
  @@index([approvedById])
}

model UOM {
  id              String          @id @default(cuid())
  code            String          @unique
  nameId          String
  nameEn          String
  description     String?
  isActive        Boolean         @default(true)
  items           Item[]
  fabricRolls     FabricRoll[]
  fromConversions UOMConversion[] @relation("FromConversions")
  toConversions   UOMConversion[] @relation("ToConversions")
  createdAt       DateTime        @default(now())
}

model UOMConversion {
  id          String   @id @default(cuid())
  fromUomId   String
  toUomId     String
  fromUom     UOM      @relation("FromConversions", fields: [fromUomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  toUom       UOM      @relation("ToConversions", fields: [toUomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  factor      Decimal  @db.Decimal(10,6)
  isDefault   Boolean  @default(false)
  @@unique([fromUomId, toUomId])
  @@index([fromUomId])
  @@index([toUomId])
}

model ItemCategory {
  id        String   @id @default(cuid())
  code      String?  @unique
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items            Item[]
  jubelioCategoryMappings JubelioCategoryMapping[]
  planCategories   PlanCategory[]
}

model Item {
  id               String            @id @default(cuid())
  sku              String            @unique
  nameId           String
  nameEn           String
  description      String?
  type             ItemType
  uomId            String
  uom              UOM               @relation(fields: [uomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  categoryId       String?
  category         ItemCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  variants         Json?
  isActive         Boolean           @default(true)
  reorderPoint     Decimal?          @db.Decimal(10,2)
  overReceiveThreshold Decimal?      @db.Decimal(10,2)
  sellingPrice     Decimal?          @db.Decimal(14,2)
  defaultPpnIncluded Boolean         @default(true)
  source           ItemSource        @default(ERP)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  stockMovements   StockMovement[]
  poItems          POItem[]
  inventoryValues  InventoryValue[]
  fgConsumptions   ConsumptionRule[] @relation("FGConsumptions")
  materialUsages   ConsumptionRule[] @relation("MaterialUsages")
  stockAdjustments StockAdjustment[]
  workOrdersAsFinishedGood WorkOrder[]
  workOrdersAsConsumptionMaterial WorkOrder[] @relation("WorkOrderConsumptionMaterial")
  planCategories   PlanCategory[]
  planAccessories  PlanAccessory[]
  rejectedGoodsLedger RejectedGoodsLedger[]
  fabricRolls      FabricRoll[]
  jubelioProductMappings JubelioProductMapping[]
  @@index([type, isActive])
  @@index([sku])
  @@index([uomId])
  @@index([categoryId])
}

model ConsumptionRule {
  id              String   @id @default(cuid())
  finishedGoodId  String
  finishedGood    Item     @relation("FGConsumptions", fields: [finishedGoodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  materialId      String
  material        Item     @relation("MaterialUsages", fields: [materialId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  qtyRequired     Decimal  @db.Decimal(10,4)
  wastePercent    Decimal  @default(0) @db.Decimal(5,2)
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  @@unique([finishedGoodId, materialId])
  @@index([finishedGoodId])
  @@index([materialId])
}

// ==========================================
// PROCUREMENT (Phase 2)
// ==========================================
model PurchaseOrder {
  id          String          @id @default(cuid())
  docNumber   String          @unique
  supplierId  String
  supplier    Supplier        @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status           POStatus        @default(DRAFT)
  etaDate          DateTime?
  paymentDueDate   DateTime?
  paidAt           DateTime?
  currency         String          @default("IDR")
  totalAmount      Decimal         @default(0) @db.Decimal(15,2)
  taxAmount        Decimal         @default(0) @db.Decimal(15,2)
  grandTotal       Decimal         @default(0) @db.Decimal(15,2)
  notes            String?        @db.Text
  terms            String?        @db.Text
  createdById      String
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items       POItem[]
  grns        GRN[]
  statusHistory POStatusHistory[]
  workOrders  WorkOrder[]
  syncStatus  SyncStatus      @default(SYNCED)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  @@index([supplierId])
  @@index([createdById])
  @@index([status])
  @@index([etaDate])
  @@index([docNumber])
}

model POItem {
  id          String        @id @default(cuid())
  poId        String
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId      String
  item        Item          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  /** Matches Item.variants[].sku; null = non-variant / parent SKU stock bucket */
  variantSku  String?
  qty         Decimal       @db.Decimal(10,2)
  price       Decimal       @db.Decimal(15,2)
  ppnIncluded Boolean       @default(true)
  receivedQty Decimal       @default(0) @db.Decimal(10,2)
  uomId       String
  notes       String?
  createdAt   DateTime      @default(now())
  @@index([poId])
  @@index([itemId])
  @@index([poId, itemId, variantSku])
}

model POStatusHistory {
  id            String        @id @default(cuid())
  poId          String
  po            PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  status        POStatus
  changedById   String
  changedBy     User          @relation(fields: [changedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes         String?
  paymentEvent  String?       // 'MARKED' | 'UNMARKED' when record is for supplier payment marked/unmarked
  createdAt     DateTime      @default(now())
  @@index([poId, createdAt])
  @@index([changedById])
}

// ==========================================
// INVENTORY & COSTING (Phase 3)
// ==========================================
model InventoryValue {
  id          String   @id @default(cuid())
  itemId      String
  variantSku  String?
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  qtyOnHand   Decimal  @default(0) @db.Decimal(10,2)
  avgCost     Decimal  @default(0) @db.Decimal(15,2)
  totalValue  Decimal  @default(0) @db.Decimal(15,2)
  lastUpdated DateTime @default(now())
  @@unique([itemId, variantSku])
  @@index([itemId])
}

model GRN {
  id            String    @id @default(cuid())
  docNumber     String    @unique
  poId          String?
  po            PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grnDate       DateTime  @default(now())
  receivedBy    String
  totalAmount   Decimal   @db.Decimal(15,2)
  notes         String?
  photoUrls     String?
  items         Json      
  requiresOwnerApproval Boolean @default(false)
  ownerApprovedAt DateTime?
  ownerApprovedById String?
  ownerApprovedBy User?    @relation("GRNOwnerApproved", fields: [ownerApprovedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ownerDeclinedAt DateTime?
  ownerDeclinedById String?
  ownerDeclinedBy User?    @relation("GRNOwnerDeclined", fields: [ownerDeclinedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  syncStatus    SyncStatus @default(SYNCED)
  localId       String?
  createdAt     DateTime  @default(now())
  fabricRolls   FabricRoll[]
  vendorReturns VendorReturn[]
  @@index([poId])
  @@index([supplierId])
  @@index([grnDate])
  @@index([docNumber])
  @@index([ownerApprovedById])
  @@index([ownerDeclinedById])
}

model FabricRoll {
  id            String   @id @default(cuid())
  grnId         String
  grn           GRN      @relation(fields: [grnId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  itemId        String
  item          Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rollCode      String   @unique
  rollRef       String
  initialLength Decimal  @db.Decimal(10,2)
  remainingLength Decimal @db.Decimal(10,2)
  uomId         String
  uom           UOM      @relation(fields: [uomId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  isClosed      Boolean  @default(false)
  notes         String?
  createdAt     DateTime @default(now())
  @@index([grnId])
  @@index([itemId])
  @@index([itemId, isClosed, remainingLength])
  @@index([uomId])
  @@index([rollCode])
}

model StockMovement {
  id           String   @id @default(cuid())
  itemId       String
  item         Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type         MoveType
  refType      String
  refId        String
  refDocNumber String
  qty          Decimal  @db.Decimal(10,2)
  variantSku   String?
  unitCost     Decimal? @db.Decimal(15,2)
  totalCost    Decimal? @db.Decimal(15,2)
  balanceQty   Decimal  @db.Decimal(10,2)
  balanceValue Decimal  @db.Decimal(15,2)
  notes        String?
  createdAt    DateTime @default(now())
  @@index([itemId, createdAt])
  @@index([refType, refId])
}

model StockAdjustment {
  id            String   @id @default(cuid())
  docNumber     String   @unique
  itemId        String
  item          Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type          AdjustmentType
  qtyChange     Decimal  @db.Decimal(10,2)
  reason        String
  evidenceUrl   String?
  prevQty       Decimal  @db.Decimal(10,2)
  newQty        Decimal  @db.Decimal(10,2)
  prevAvgCost   Decimal  @db.Decimal(15,2)
  newAvgCost    Decimal  @db.Decimal(15,2)
  approvedById  String?
  approvedBy    User?    @relation("ApprovedAdjustments", fields: [approvedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdById   String?
  createdBy     User?    @relation("CreatedAdjustments", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  source           String   @default("ERP")
  idempotencyKey   String?  @unique
  externalRef      String?
  createdAt     DateTime @default(now())
  @@index([itemId])
  @@index([approvedById])
  @@index([createdById])
  @@index([docNumber])
  @@index([source, createdAt])
}

// ==========================================
// PRODUCTION (Phase 4)
// ==========================================
model WorkOrder {
  id              String    @id @default(cuid())
  docNumber       String    @unique
  poId            String?
  po              PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendorId        String
  vendor          Supplier  @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  finishedGoodId  String
  finishedGood    Item      @relation(fields: [finishedGoodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  consumptionMaterialId String?
  consumptionMaterial   Item?     @relation("WorkOrderConsumptionMaterial", fields: [consumptionMaterialId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  outputMode      OutputMode @default(GENERIC)
  plannedQty      Decimal   @db.Decimal(10,2)
  expectedConsumption Decimal? @db.Decimal(10,2)
  actualQty       Decimal?  @db.Decimal(10,2)
  targetDate      DateTime?
  status          WOStatus  @default(DRAFT)
  issuedAt        DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  canceledReason  String?
  consumptionPlan Json
  skuBreakdown    Json?
  rollBreakdown   Json?     // Optional: [{ rollRef: string, qty: number, notes?: string }], sum qty = plannedQty
  hppMarginPercent Decimal? @db.Decimal(5,2)
  hppAdditionalCost Decimal? @db.Decimal(15,2)
  notes           String?
  syncStatus      SyncStatus @default(SYNCED)
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  issues          MaterialIssue[]
  receipts        FGReceipt[]
  returns         VendorReturn[]
  steps           WorkOrderStep[]
  planStages      PlanStage[] @relation("PlanStageWorkOrder")
  @@index([poId])
  @@index([vendorId])
  @@index([finishedGoodId])
  @@index([consumptionMaterialId])
  @@index([createdById])
  @@index([status])
  @@index([targetDate])
  @@index([docNumber])
}

model WorkOrderStep {
  id                 String   @id @default(cuid())
  woId               String
  wo                 WorkOrder @relation(fields: [woId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sequence           Int
  stepName           String?
  supplierId         String
  supplier           Supplier @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  servicePrice       Decimal  @default(0) @db.Decimal(15,2)
  servicePpnIncluded Boolean  @default(false)
  qty                Decimal? @db.Decimal(10,2)
  totalCost          Decimal? @db.Decimal(15,2)
  issueDocNumber     String?
  receiptDocNumber   String?
  issuedAt           DateTime?
  receivedAt         DateTime?
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  @@index([woId])
  @@index([supplierId])
  @@unique([woId, sequence])
}

model MaterialIssue {
  id            String    @id @default(cuid())
  docNumber     String    @unique
  woId          String
  wo            WorkOrder @relation(fields: [woId], references: [id], onDelete: Cascade)
  issueType     IssueType
  parentIssueId String?
  isPartial     Boolean   @default(false)
  splitSequence Int?
  items         Json
  totalCost     Decimal   @db.Decimal(15,2)
  issuedById    String
  issuedAt      DateTime  @default(now())
  acknowledged  Boolean   @default(false)
  ackAt         DateTime?
  ackPhotoUrl   String?
  syncStatus    SyncStatus @default(SYNCED)
  notes         String?   @db.Text
  @@index([woId])
  @@index([issuedById])
  @@index([issuedAt])
  @@index([docNumber])
}

model FGReceipt {
  id             String    @id @default(cuid())
  docNumber      String    @unique
  woId           String
  wo             WorkOrder @relation(fields: [woId], references: [id], onDelete: Cascade)
  receiptType    ReceiptType
  qtyReceived    Decimal   @db.Decimal(10,2)
  qtyRejected    Decimal   @default(0) @db.Decimal(10,2)
  qtyAccepted    Decimal   @db.Decimal(10,2)
  skuBreakdown   Json?
  qcPassed       Boolean   @default(true)
  qcNotes        String?
  qcPhotos       String?
  materialCost   Decimal?  @db.Decimal(15,2)
  avgCostPerUnit Decimal?  @db.Decimal(15,2)
  totalCostValue Decimal?  @db.Decimal(15,2)
  receivedById   String
  receivedAt     DateTime  @default(now())
  syncStatus     SyncStatus @default(SYNCED)
  @@index([woId])
  @@index([receivedById])
  @@index([receivedAt])
  @@index([docNumber])
}

model RejectedGoodsLedger {
  id          String    @id @default(cuid())
  itemId      String
  item        Item      @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  variantSku  String?
  qty         Decimal   @db.Decimal(10,2)
  refType     String    // FG_RECEIPT
  refId       String
  refDocNumber String
  woId        String?
  receivedAt  DateTime
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  @@index([itemId])
  @@index([refType, refId])
  @@index([woId])
  @@index([receivedAt])
}

model VendorReturn {
  id               String       @id @default(cuid())
  docNumber        String       @unique
  woId             String?
  wo               WorkOrder?   @relation(fields: [woId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendorId         String
  vendor           Supplier     @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  grnId            String?
  grn              GRN?         @relation(fields: [grnId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  lines            Json
  totalItems       Int
  totalValue       Decimal      @db.Decimal(15,2)
  evidenceUrls     String?
  status           ReturnStatus @default(DRAFT)
  processedAt      DateTime?
  processedBy      String?
  stockImpacted    Boolean      @default(false)
  trackingNumber   String?
  receiptFileUrl   String?
  completedAt      DateTime?
  completedById    String?
  completedBy      User?        @relation("VendorReturnCompleted", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  syncStatus       SyncStatus   @default(SYNCED)
  createdById      String
  createdBy        User         @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt        DateTime     @default(now())
  @@index([woId])
  @@index([vendorId])
  @@index([grnId])
  @@index([status])
  @@index([createdById])
  @@index([completedById])
}

// ==========================================
// PRODUCTION PLANNING (Plan Kerja)
// ==========================================
model PlanYear {
  id          String          @id @default(cuid())
  year        Int             @unique
  notes       String?         @db.Text
  isLocked    Boolean         @default(false)
  categories  PlanCategory[]
  createdById String
  createdBy   User            @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([createdById])
}

model PlanCategory {
  id                  String                @id @default(cuid())
  planYearId          String
  planYear            PlanYear              @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  code                String
  name                String
  description         String?
  parentId            String?
  parent              PlanCategory?         @relation("PlanCategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children            PlanCategory[]        @relation("PlanCategoryHierarchy")
  targetQty           Int?
  parentSharePercent  Decimal?              @db.Decimal(5,2)
  itemId              String?
  item                Item?                 @relation(fields: [itemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  itemCategoryId      String?
  itemCategory        ItemCategory?         @relation(fields: [itemCategoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  monthlyTargets      PlanMonthly[]
  stages              PlanStage[]
  colorAllocations    PlanColorAllocation[]
  cmtAllocations      PlanCmtAllocation[]
  accessoryPlans      PlanAccessory[]
  sortOrder           Int                   @default(0)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@unique([planYearId, code])
  @@unique([planYearId, itemCategoryId])
  @@index([planYearId])
  @@index([parentId])
  @@index([itemId])
  @@index([itemCategoryId])
}

model PlanMonthly {
  id                String        @id @default(cuid())
  planCategoryId    String
  planCategory      PlanCategory  @relation(fields: [planCategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  month             Int
  targetQty         Int?
  isManualOverride  Boolean       @default(false)
  notes             String?

  @@unique([planCategoryId, month])
  @@index([planCategoryId])
}

model PlanStage {
  id                String        @id @default(cuid())
  planCategoryId    String
  planCategory      PlanCategory  @relation(fields: [planCategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name              String
  targetQty         Int
  targetMonth       Int?
  supplierId        String?
  supplier          Supplier?     @relation("PlanStageSupplier", fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fabricNotes       String?
  colorNotes        String?
  workOrderId       String?
  workOrder         WorkOrder?    @relation("PlanStageWorkOrder", fields: [workOrderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sortOrder         Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([planCategoryId])
  @@index([supplierId])
  @@index([workOrderId])
}

model PlanColorAllocation {
  id                String        @id @default(cuid())
  planCategoryId    String
  planCategory      PlanCategory  @relation(fields: [planCategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  colorName         String
  colorCode         String?
  allocatedQty      Int
  notes             String?

  @@unique([planCategoryId, colorName])
  @@index([planCategoryId])
}

model PlanCmtAllocation {
  id                String        @id @default(cuid())
  planCategoryId    String
  planCategory      PlanCategory  @relation(fields: [planCategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  supplierId        String
  supplier          Supplier      @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  allocatedQty      Int
  notes             String?

  @@index([planCategoryId])
  @@index([supplierId])
}

model PlanAccessory {
  id                String        @id @default(cuid())
  planCategoryId    String
  planCategory      PlanCategory  @relation(fields: [planCategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  itemId            String
  item              Item          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  qtyPerPcs         Decimal       @db.Decimal(10,4)
  totalQtyNeeded    Int
  notes             String?

  @@index([planCategoryId])
  @@index([itemId])
}

// ==========================================
// S&OP FORECAST
// ==========================================
model SalesHistory {
  id                     String             @id @default(cuid())
  channel                SalesChannel
  orderId                String
  orderStatus            SalesHistoryStatus
  variantSku             String
  parentSku              String
  productName            String
  color                  String?
  size                   String?
  quantity               Int
  returnedQuantity       Int                @default(0)
  netQuantity            Int
  unitPrice              Decimal            @db.Decimal(15, 2)
  unitPriceAfterDiscount Decimal            @db.Decimal(15, 2)
  lineTotal              Decimal            @db.Decimal(15, 2)
  orderTotal             Decimal            @db.Decimal(15, 2)
  orderDate              DateTime
  completedDate          DateTime?
  province               String?
  city                   String?
  productCategory        String?
  importBatchId          String
  importBatch            SalesHistoryImport @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  createdAt              DateTime           @default(now())

  @@unique([channel, orderId, variantSku])
  @@index([parentSku, orderDate])
  @@index([orderDate])
  @@index([channel])
  @@index([importBatchId])
  @@index([orderStatus])
}

model SalesHistoryImport {
  id           String         @id @default(cuid())
  channel      SalesChannel
  fileName     String
  periodMonth  Int
  periodYear   Int
  totalRows    Int
  importedRows Int
  skippedRows  Int            @default(0)
  errorRows    Int            @default(0)
  errors       Json?
  uploadedById String
  uploadedBy   User           @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime       @default(now())
  rows         SalesHistory[]

  @@unique([channel, periodYear, periodMonth])
  @@index([uploadedById])
}

model ForecastConfig {
  id                  String   @id @default(cuid())
  year                Int      @unique
  growthFactorPercent Decimal  @default(0) @db.Decimal(5, 2)
  lookbackMonths      Int      @default(12)
  weightDecay         Decimal  @default(0.90) @db.Decimal(3, 2)
  notes               String?  @db.Text
  createdById         String
  createdBy           User     @relation(fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([createdById])
}

model ForecastResult {
  id                     String   @id @default(cuid())
  year                   Int
  parentSku              String
  productName            String
  abcClass               ABCClass
  xyzClass               XYZClass
  totalHistoricalQty     Int
  totalHistoricalRevenue Decimal  @db.Decimal(15, 2)
  avgMonthlyDemand       Decimal  @db.Decimal(10, 2)
  coefficientOfVariation Decimal  @db.Decimal(5, 4)
  forecastMonth1         Int      @default(0)
  forecastMonth2         Int      @default(0)
  forecastMonth3         Int      @default(0)
  forecastMonth4         Int      @default(0)
  forecastMonth5         Int      @default(0)
  forecastMonth6         Int      @default(0)
  forecastMonth7         Int      @default(0)
  forecastMonth8         Int      @default(0)
  forecastMonth9         Int      @default(0)
  forecastMonth10        Int      @default(0)
  forecastMonth11        Int      @default(0)
  forecastMonth12        Int      @default(0)
  forecastAnnual         Int      @default(0)
  seasonalIndex1         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex2         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex3         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex4         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex5         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex6         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex7         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex8         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex9         Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex10        Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex11        Decimal  @default(1) @db.Decimal(5, 4)
  seasonalIndex12        Decimal  @default(1) @db.Decimal(5, 4)
  generatedAt            DateTime @default(now())

  @@unique([year, parentSku])
  @@index([year])
  @@index([abcClass, xyzClass])
}

enum SalesChannel {
  SHOPEE
  TIKTOK
}

enum SalesHistoryStatus {
  COMPLETED
  CANCELLED
  RETURNED
}

enum ABCClass {
  A
  B
  C
}

enum XYZClass {
  X
  Y
  Z
}

// ==========================================
// SYSTEM & AUDIT (Phase 5)
// ==========================================
model AuditLog {
  id                    String   @id @default(cuid())
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action                String
  entityType            String
  entityId              String
  changes               Json?
  metadata              Json?
  sensitiveDataAccessed String?
  reason                String?
  ipAddress             String?
  userAgent             String?
  createdAt             DateTime @default(now())
  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

model DocNumberConfig {
  id          String   @id @default(cuid())
  docType     DocType  @unique
  prefix      String
  resetPeriod String   // YEARLY, MONTHLY, NEVER
  padding     Int      @default(4)
  lastNumber  Int      @default(0)
  year        Int      @default(0)
  month       Int      @default(0)
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

// ==========================================
// JUBELIO INTEGRATION
// ==========================================


model NotificationQueue {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      Json?
  sent      Boolean   @default(false)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  @@index([userId, sent])
  @@index([createdAt])
}

model PinAttempt {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  success   Boolean
  ipAddress String?
  createdAt DateTime @default(now())
  @@index([userId, createdAt])
}

model DocumentNumber {
  id         String   @id @default(cuid())
  docType    DocType
  prefix     String
  year       Int
  month      Int?
  lastNumber Int
  format     String
  @@unique([docType, year, month])
}


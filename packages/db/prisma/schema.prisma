  notes             String?
  planStage         PlanStage?

  @@unique([planCategoryId, month, variantSku, supplierId])
  @@index([planCategoryId])
  @@index([supplierId])
  @@index([workOrderId])
}

model PlanAccessory {
  id                String        @id @default(cuid())

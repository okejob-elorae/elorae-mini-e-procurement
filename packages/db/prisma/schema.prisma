}

model PlanCategory {
  id                  String                @id @default(cuid())
  planYearId          String
  planYear            PlanYear              @relation(fields: [planYearId], references: [id], onDelete: Cascade)
  code                String
  name                String
  description         String?
  parentId            String?
  parent              PlanCategory?         @relation("PlanCategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children            PlanCategory[]        @relation("PlanCategoryHierarchy")
  targetQty           Int?
  parentSharePercent  Decimal?              @db.Decimal(5,2)
  itemId              String?
  item                Item?                 @relation(fields: [itemId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  itemCategoryId      String?
  itemCategory        ItemCategory?         @relation(fields: [itemCategoryId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  monthlyTargets      PlanMonthly[]

model WorkOrder {
  id              String    @id @default(cuid())
  docNumber       String    @unique
  poId            String?
  po              PurchaseOrder? @relation(fields: [poId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vendorId        String
  vendor          Supplier  @relation(fields: [vendorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  finishedGoodId  String
  finishedGood    Item      @relation(fields: [finishedGoodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  consumptionMaterialId String?
  consumptionMaterial   Item?     @relation("WorkOrderConsumptionMaterial", fields: [consumptionMaterialId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  outputMode      OutputMode @default(GENERIC)
  plannedQty      Decimal   @db.Decimal(10,2)
  expectedConsumption Decimal? @db.Decimal(10,2)
  actualQty       Decimal?  @db.Decimal(10,2)
  targetDate      DateTime?
  status          WOStatus  @default(DRAFT)
  issuedAt        DateTime?
  completedAt     DateTime?
  canceledAt      DateTime?
  canceledReason  String?
  consumptionPlan Json
  skuBreakdown    Json?
  rollBreakdown   Json?     // Optional: [{ rollRef: string, qty: number, notes?: string }], sum qty = plannedQty
  hppMarginPercent Decimal? @db.Decimal(5,2)
  hppAdditionalCost Decimal? @db.Decimal(15,2)
  notes           String?
  syncStatus      SyncStatus @default(SYNCED)
  createdById     String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  issues          MaterialIssue[]
  receipts        FGReceipt[]
  returns         VendorReturn[]

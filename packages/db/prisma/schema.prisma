  @@unique([planCategoryId, month, variantSku])
  @@index([planCategoryId])
}

model PlanCmtAllocation {
  id                String        @id @default(cuid())
  planCategoryId    String
  planCategory      PlanCategory  @relation(fields: [planCategoryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  month             Int
  variantSku        String

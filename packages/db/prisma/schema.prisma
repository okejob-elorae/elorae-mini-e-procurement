  name                  String
  targetQty             Int
  targetMonth           Int?
  variantSku            String?
  supplierId            String?
  supplier              Supplier?           @relation("PlanStageSupplier", fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)

# apps/api — NestJS Jubelio integration env contract.
# Canonical location: repo-root /.env (shared with apps/web via symlink).
# At runtime bootstrap-env.ts also accepts apps/api/.env if you want api-only overrides.
# Never commit real secrets.

# ────────────────────────────────────────────────
# Database (mirror of apps/web — same TiDB / MySQL)
# ────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@127.0.0.1:3306/elorae

# ────────────────────────────────────────────────
# HTTP server
# ────────────────────────────────────────────────
# Defaults to 3001 if unset. apps/web runs on 3000. Render injects PORT=10000.
PORT=3001

# ────────────────────────────────────────────────
# CORS — comma-separated allowed origins. Empty = CORS disabled (same-origin only).
# Use "*" only for dev. In prod set the apps/web Vercel URL(s).
# Example: https://elorae.vercel.app,https://elorae-staging.vercel.app
# ────────────────────────────────────────────────
CORS_ORIGINS=

# ────────────────────────────────────────────────
# Swagger /docs (HTTP Basic auth). If either is missing, /docs is disabled.
# ────────────────────────────────────────────────
SWAGGER_USER=
SWAGGER_PASS=

# ────────────────────────────────────────────────
# Jubelio integration
# ────────────────────────────────────────────────
# Base URL. Defaults to https://api2.jubelio.com if unset.
JUBELIO_API_BASE_URL=https://api2.jubelio.com

# Account credentials. The api refreshes its 12h session token via POST /login
# and stores it in the SystemSetting row keyed JUBELIO_SESSION_TOKEN.
JUBELIO_USER=
JUBELIO_PASS=

# Webhook signature secret. Set in Jubelio dashboard → Pengaturan → Developer →
# Webhook. apps/api verifies sha256(rawBody + secret) on every inbound webhook.
JUBELIO_WEBHOOK_SECRET=

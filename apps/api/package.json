{
  "name": "@elorae/api",
  "version": "0.1.0",
  "private": true,
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@elorae/db$": "<rootDir>/../../../packages/db/dist/src/index.js",
      "^@elorae/db/(.*)$": "<rootDir>/../../../packages/db/dist/src/$1.js"
    }
  },
  "scripts": {
    "dev": "nest start --watch --builder swc",
    "build": "nest build",
    "start": "node dist/main.js",
    "migrate:deploy": "pnpm --filter @elorae/db migrate:deploy",
    "prod:build": "pnpm --filter @elorae/db generate && pnpm --filter @elorae/db build && pnpm --filter @elorae/api build",
    "prod:start": "NODE_ENV=production node dist/main.js",
    "prod": "pnpm prod:build && pnpm migrate:deploy && pnpm prod:start",
    "lint": "eslint src --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@elorae/db": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.0.0",
    "@nestjs/swagger": "^11.0.0",
    "dotenv": "^16.6.1",
    "express-basic-auth": "^1.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}

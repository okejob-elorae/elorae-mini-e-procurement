# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/agent-instruction

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/generated

/.playwright-mcp

.cursor

# Serwist-generated service worker (built from app/pwa/sw.ts)
public/pwa/sw.js
public/pwa/swe-worker-*.js

# next-pwa-generated root service worker + workbox chunks (build artifacts — never commit;
# committing them lets a stale workbox-<hash>.js poison the build's precache manifest → 404)
public/sw.js
public/sw.js.map
public/workbox-*.js
public/worker-*.js
public/fallback-*.js
# apps/web — Next.js ERP env contract.
# Copy to apps/web/.env. Never commit real secrets.

# ────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────
# Local MySQL/MariaDB:  mysql://user:pass@127.0.0.1:3306/elorae
# TiDB Cloud:           mysql://user:pass@host:4000/elorae?sslaccept=strict
DATABASE_URL=mysql://user:password@127.0.0.1:3306/elorae

# ────────────────────────────────────────────────
# NextAuth
# ────────────────────────────────────────────────
# 32+ byte secret for JWT signing. Generate: openssl rand -base64 32
# AUTH_SECRET is the v5 name; NEXTAUTH_SECRET is the legacy alias. Either works.
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ────────────────────────────────────────────────
# Encryption (supplier PII, AES-256)
# ────────────────────────────────────────────────
# 32 hex bytes. Generate: openssl rand -hex 32
ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# ────────────────────────────────────────────────
# Internal apps/api URL (server-action proxy target for Jubelio endpoints)
# Defaults to http://localhost:3001 if unset.
# ────────────────────────────────────────────────
INTERNAL_API_URL=http://localhost:3001

# ────────────────────────────────────────────────
# Cron endpoint guard (POST /api/cron/...)
# ────────────────────────────────────────────────
# Optional in dev; required in production. Bearer this in Vercel Cron jobs.
CRON_SECRET=

# ────────────────────────────────────────────────
# Firebase — client SDK (PWA push notifications)
# NEXT_PUBLIC_* are bundled into the browser.
# ────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=elorae-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=elorae-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=elorae-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ────────────────────────────────────────────────
# Firebase — Admin SDK (server-side notification dispatch)
# Optional in dev; required in production.
# ────────────────────────────────────────────────
FIREBASE_ADMIN_PROJECT_ID=elorae-prod
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@elorae-prod.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ────────────────────────────────────────────────
# Cloudflare R2 (file uploads, GRN photos)
# ────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=elorae-uploads
R2_PUBLIC_URL=https://uploads.elorae.com
R2_JURISDICTION_ENDPOINT=
R2_TOKEN_VALUE=

# Production environment for the Hostinger VPS deploy.
# Copy this to .env.production on the server and fill in real values.
# DO NOT commit .env.production — it's in .gitignore.

# ────────────────────────────────────────────────
# HTTP server
# ────────────────────────────────────────────────
PORT=3001

# Comma-separated allowed origins. apps/web Vercel URL(s).
# Example: https://elorae.vercel.app,https://elorae-staging.vercel.app
CORS_ORIGINS=https://elorae.vercel.app

# ────────────────────────────────────────────────
# Swagger /docs (HTTP Basic auth). Disabled if either missing.
# ────────────────────────────────────────────────
SWAGGER_USER=
SWAGGER_PASS=

# ────────────────────────────────────────────────
# Database — self-hosted MariaDB on the same VPS (docker-compose service `db`).
# Inline the password — env_file values are NOT interpolated by Compose. Same
# value goes into apps/web's .env.production.web DATABASE_URL.
#
# Hostname `db` is the docker-compose service name — resolves on the internal
# network. From the VPS host itself, you'd use 127.0.0.1:3306; from local dev,
# SSH-tunnel and point at 127.0.0.1:3306 too.
# ────────────────────────────────────────────────
DATABASE_URL=mysql://elorae:<DB_PASSWORD>@db:3306/elorae

# ────────────────────────────────────────────────
# MariaDB credentials — referenced from docker-compose.prod.yml's `db` service.
# Compose reads these from the project `.env` (Docker's auto-loaded file), NOT
# from .env.production. Create a `.env` next to docker-compose.prod.yml on the
# VPS with these two lines, generated by `openssl rand -base64 32`:
#
#   DB_ROOT_PASSWORD=<random>
#   DB_PASSWORD=<random — same value as DATABASE_URL above>
#
# Keep both out of git (.gitignore covers .env).
# ────────────────────────────────────────────────

# ────────────────────────────────────────────────
# Jubelio integration
# ────────────────────────────────────────────────
JUBELIO_API_BASE_URL=https://api2.jubelio.com
JUBELIO_USER=
JUBELIO_PASS=
JUBELIO_WEBHOOK_SECRET=

# ────────────────────────────────────────────────
# Internal signed channel (web → api)
# Must match apps/web's INTERNAL_API_SECRET (Vercel env). Used by
# internal-sign.guard.ts to authenticate web → api calls.
# ────────────────────────────────────────────────
INTERNAL_API_SECRET=

# REDIS_URL is injected by docker-compose.prod.yml — leave commented here.
# REDIS_URL=redis://redis:6379

# NODE_ENV is set by docker-compose.prod.yml.
# NODE_ENV=production

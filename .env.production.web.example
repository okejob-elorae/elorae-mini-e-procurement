# Production env for apps/web on the Hostinger VPS.
# Copy to .env.production.web on the server and fill in real values.
# DO NOT commit .env.production.web — it's in .gitignore via .env.* pattern.

# Server runtime
NODE_ENV=production
PORT=3000

# Database — same TiDB instance as apps/api
DATABASE_URL=

# NextAuth — must match between web restarts (don't rotate without re-issuing all sessions)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://elorae.cloud

# Supplier PII encryption
ENCRYPTION_KEY=

# Internal signed channel to apps/api (in-container hostname, NOT public URL)
INTERNAL_API_URL=http://api:3001
INTERNAL_API_SECRET=

# Cron route guard (still useful for manual smoke; in-process cron bypasses it)
CRON_SECRET=

# Firebase — client SDK (NEXT_PUBLIC_* are bundled at build time, set in Dockerfile build args if needed)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=elorae-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=elorae-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=elorae-prod.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Admin SDK (server-side push)
FIREBASE_ADMIN_PROJECT_ID=elorae-prod
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Cloudflare R2
# (add your R2 keys here per .env.example)

# Redis (BullMQ instance, shared via Docker internal network)
# In docker-compose: redis://redis:6379
# For local-dev outside Docker: redis://localhost:6379
REDIS_URL=redis://redis:6379
